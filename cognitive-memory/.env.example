# ── Required ──────────────────────────────────────────────────
# OpenAI API key — used for text-embedding-3-small embeddings
OPENAI_API_KEY=sk-...

# ── LLM Provider (choose one) ────────────────────────────────
# Option A: Direct Anthropic API
ANTHROPIC_API_KEY=sk-ant-...

# Option B: Amazon Bedrock (set these instead of ANTHROPIC_API_KEY)
# AWS_ACCESS_KEY_ID=...
# AWS_SECRET_ACCESS_KEY=...
# AWS_DEFAULT_REGION=us-east-1

# ── Optional: LLM Model Override ─────────────────────────────
# By default, extraction uses claude-sonnet-4-5 and profile building
# uses claude-sonnet-4-6. Set CMM_LLM_MODEL to override both with a
# single LiteLLM model string.
#
# Full list of supported models and pricing:
# https://raw.githubusercontent.com/BerriAI/litellm/main/model_prices_and_context_window.json
#
# For direct Anthropic API:
# CMM_LLM_MODEL=anthropic/claude-sonnet-4-6
# CMM_LLM_MODEL=anthropic/claude-opus-4-6
#
# For Amazon Bedrock (inference profiles -- note the us. prefix):
# CMM_LLM_MODEL=bedrock/us.anthropic.claude-sonnet-4-6
# CMM_LLM_MODEL=bedrock/us.anthropic.claude-opus-4-6-v1
# CMM_LLM_MODEL=bedrock/us.anthropic.claude-sonnet-4-5-20250929-v1:0

# ── Optional: Memory Store ────────────────────────────────────
# CMM_STORE_PATH=~/.cognitive-memory/store
# CMM_PROJECT_ID=my-project
# CMM_CONTEXT_FILL_RATIO=0.45

# ── Optional: Shared/Team Mode (Chroma Cloud) ────────────────
# CMM_CHROMA_API_KEY=ck-...
# CMM_CHROMA_TENANT=<tenant-uuid>
# CMM_CHROMA_DATABASE=cmm
# CMM_DEVELOPER_NAME=yourname

# ── Optional: Shared/Team Mode (filesystem) ──────────────────
# CMM_SHARED_STORE_PATH=/shared/team/memory_store
